    "# Cell 6 — Preference-margin sanity check on the eval split\n",
    "# This checks whether the trained policy assigns higher average log-probability to chosen than rejected outputs.\n",
    "# Real Week 11 ablations still run locally on held_out/tasks.jsonl with scoring_evaluator.py.\n",
    "\n",
    "import math\n",
    "\n",
    "import torch.nn.functional as F\n",
    "\n",
    "FastLanguageModel.for_inference(model)\n",
    "model.eval()\n",
    "\n",
    "def completion_avg_logprob(prompt: str, completion: str) -> float:\n",
    "    text = prompt.rstrip() + \"\\n\\n\" + completion.lstrip()\n",
    "    prompt_ids = tokenizer(prompt.rstrip() + \"\\n\\n\", return_tensors=\"pt\", truncation=True, max_length=MAX_SEQ_LEN)[\"input_ids\"]\n",
    "    encoded = tokenizer(text, return_tensors=\"pt\", truncation=True, max_length=MAX_SEQ_LEN).to(model.device)\n",
    "    input_ids = encoded[\"input_ids\"]\n",
    "    with torch.no_grad():\n",
    "        logits = model(**encoded).logits[:, :-1, :]\n",
    "    labels = input_ids[:, 1:]\n",
    "    log_probs = F.log_softmax(logits, dim=-1).gather(-1, labels.unsqueeze(-1)).squeeze(-1)\n",
    "    start = max(0, min(prompt_ids.shape[1] - 1, log_probs.shape[1] - 1))\n",
    "    completion_log_probs = log_probs[:, start:]\n",
    "    return float(completion_log_probs.mean().detach().cpu())\n",
    "\n",
    "margins = []\n",
    "for row in eval_rows:\n",
    "    chosen_lp = completion_avg_logprob(row[\"prompt\"], row[\"chosen\"])\n",
    "    rejected_lp = completion_avg_logprob(row[\"prompt\"], row[\"rejected\"])\n",
    "    margins.append(chosen_lp - rejected_lp)\n",
    "\n",
    "pref_accuracy = sum(m > 0 for m in margins) / len(margins) if margins else math.nan\n",
    "mean_margin = sum(margins) / len(margins) if margins else math.nan\n",
    "eval_summary = {\"eval_pairs\": len(margins), \"preference_accuracy\": pref_accuracy, \"mean_margin\": mean_margin}\n",
    "(artifact_dir / \"eval_preference_margin.json\").write_text(json.dumps(eval_summary, indent=2) + \"\\n\")\n",
    "\n",
    "print(json.dumps(eval_summary, indent=2))\n",
    "print(\"Saved: training_artifacts/eval_preference_margin.json\")"
   ]
  },
