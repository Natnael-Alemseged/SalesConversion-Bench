    "import json\n",
    "import time\n",
    "from pathlib import Path\n",
    "\n",
    "heldout_path = Path(\"tasks.jsonl\")\n",
    "assert heldout_path.exists(), \"Upload tenacious_bench_v0.2/held_out/tasks.jsonl as /content/held_out_tasks.jsonl\"\n",
    "\n",
    "heldout = [json.loads(l) for l in heldout_path.open() if l.strip()]\n",
    "print(\"held_out tasks:\", len(heldout))\n",
    "\n",
    "out_path = Path(\"training_artifacts/held_out_traces_raw.jsonl\")\n",
    "with out_path.open(\"w\") as f:\n",
    "    for task in heldout:\n",
    "        prompt = \"[SYSTEM]\\nScore this Tenacious outreach draft as PASS or FAIL. Return only JSON with keys: verdict, reason.\\n\\n\"\n",
    "        prompt += \"[TASK]\\n\" + json.dumps(task, ensure_ascii=False)\n",
    "\n",
    "        inputs = tokenizer(prompt, return_tensors=\"pt\", truncation=True, max_length=1024).to(model.device)\n",
    "\n",
    "        start = time.time()\n",
    "        output = model.generate(\n",
    "            **inputs,\n",
    "            max_new_tokens=120,\n",
    "            do_sample=False,\n",
    "            temperature=None,\n",
    "            top_p=None,\n",
    "        )\n",
    "        latency_ms = round((time.time() - start) * 1000, 2)\n",
    "\n",
    "        text = tokenizer.decode(output[0][inputs[\"input_ids\"].shape[1]:], skip_special_tokens=True)\n",
    "\n",
    "        f.write(json.dumps({\n",
    "            \"task_id\": task[\"task_id\"],\n",
    "            \"verdict\": text.strip(),\n",
    "            \"latency_ms\": latency_ms,\n",
    "        }) + \"\\n\")\n"
   ]
