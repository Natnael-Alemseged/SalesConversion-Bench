    "# Cell 4 — SimPO training\n",
    "import inspect\n",
    "\n",
    "import torch\n",
    "from trl import CPOConfig\n",
    "\n",
    "config_params = inspect.signature(CPOConfig.__init__).parameters\n",
    "eval_key = \"eval_strategy\" if \"eval_strategy\" in config_params else \"evaluation_strategy\"\n",
    "\n",
    "config_kwargs = dict(\n",
    "    loss_type=\"simpo\",\n",
    "    beta=2.0,\n",
    "    simpo_gamma=0.5,\n",
    "    per_device_train_batch_size=2,\n",
    "    per_device_eval_batch_size=2,\n",
    "    gradient_accumulation_steps=4,\n",
    "    num_train_epochs=3,\n",
    "    learning_rate=5e-5,\n",
    "    lr_scheduler_type=\"cosine\",\n",
    "    warmup_ratio=0.1,\n",
    "    fp16=True,\n",
    "    bf16=False,\n",
    "    logging_steps=5,\n",
    "    save_strategy=\"epoch\",\n",
    "    output_dir=\"tenacious_judge_simpo\",\n",
    "    seed=SEED,\n",
    "    max_length=MAX_SEQ_LEN,\n",
    "    max_prompt_length=768,\n",
    "    report_to=\"none\",\n",
    "    remove_unused_columns=False,\n",
    ")\n",
    "\n",
    "config_kwargs[eval_key] = \"epoch\"\n",
    "training_args = CPOConfig(**config_kwargs)\n",
    "\n",
    "# Critical: disable datasets multiprocessing, otherwise Colab/Unsloth can fail\n",
    "# with: TypeError: cannot pickle 'ConfigModuleInstance' object.\n",
    "training_args.dataset_num_proc = None\n",
    "print(\"dataset_num_proc =\", training_args.dataset_num_proc)\n",
    "\n",
    "trainer_params = inspect.signature(VanillaCPOTrainer.__init__).parameters\n",
    "trainer_kwargs = dict(\n",
    "    model=model,\n",
    "    args=training_args,\n",
    "    train_dataset=train_data,\n",
    "    eval_dataset=eval_data,\n",
    ")\n",
    "\n",
    "if \"processing_class\" in trainer_params:\n",
    "    trainer_kwargs[\"processing_class\"] = tokenizer\n",
    "else:\n",
    "    trainer_kwargs[\"tokenizer\"] = tokenizer\n",
    "\n",
    "trainer = VanillaCPOTrainer(**trainer_kwargs)\n",
    "\n",
    "print(\"Starting SimPO training...\")\n",
    "train_result = trainer.train()\n",
    "print(\"\\nTraining complete.\")\n",
    "print(train_result.metrics)\n"
   ]
  },
