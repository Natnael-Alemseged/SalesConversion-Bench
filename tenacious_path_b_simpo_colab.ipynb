   "source": [
    "# Cell 2 — Load text-only model + LoRA. Import CPOTrainer BEFORE unsloth; Cell 4 uses VanillaCPOTrainer.\n",
    "import torch\n",
    "\n",
    "if not torch.cuda.is_available():\n",
    "    raise RuntimeError(\"Use Runtime → Change runtime type → GPU.\")\n",
    "\n",
    "os.environ[\"UNSLOTH_COMPILE_DISABLE\"] = \"1\"\n",
    "\n",
    "from trl import CPOTrainer as VanillaCPOTrainer\n",
    "from unsloth import FastLanguageModel\n",
    "\n",
    "SEED = 3407\n",
    "MAX_SEQ_LEN = 1024\n",
    "BACKBONE_MODEL = \"unsloth/Qwen2.5-0.5B-Instruct\"\n",
    "BACKBONE_NOTE = \"Operational text-only fallback; Qwen3.5-0.8B is currently multimodal and breaks TRL CPO tokenization on text-only preference pairs.\"\n",
    "\n",
    "dtype = torch.float16\n",
    "print(f\"dtype: {dtype} | GPU: {torch.cuda.get_device_name(0)}\")\n",
    "\n",
    "model, tokenizer = FastLanguageModel.from_pretrained(\n",
    "    model_name=BACKBONE_MODEL,\n",
    "    max_seq_length=MAX_SEQ_LEN,\n",
    "    dtype=dtype,\n",
    "    load_in_4bit=False,\n",
    ")\n",
    "if tokenizer.pad_token is None:\n",
    "    tokenizer.pad_token = tokenizer.eos_token\n",
    "\n",
    "model = FastLanguageModel.get_peft_model(\n",
    "    model,\n",
    "    r=16,\n",
    "    target_modules=[\"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\", \"gate_proj\", \"up_proj\", \"down_proj\"],\n",
    "    lora_alpha=32,\n",
    "    lora_dropout=0.05,\n",
    "    bias=\"none\",\n",
    "    use_gradient_checkpointing=\"unsloth\",\n",
    "    random_state=SEED,\n",
    "    use_rslora=False,\n",
    ")\n",
    "print(\"Model loaded.\")"
   ]
  },
