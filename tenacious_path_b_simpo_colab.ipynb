    "# Cell 7 — Save and push LoRA adapter to HuggingFace\n",
    "from pathlib import Path\n",
    "\n",
    "from google.colab import userdata\n",
    "from huggingface_hub import HfApi\n",
    "\n",
    "hf_token = userdata.get(\"HF_TOKEN\")\n",
    "if not hf_token:\n",
    "    raise RuntimeError(\"Add a HuggingFace write token to Colab Secrets as HF_TOKEN before pushing.\")\n",
    "\n",
    "api = HfApi()\n",
    "hf_user = api.whoami(token=hf_token)[\"name\"]\n",
    "repo_name = \"tenacious-judge-lora\"\n",
    "repo_id = f\"{hf_user}/{repo_name}\"\n",
    "\n",
    "api.create_repo(repo_id=repo_id, token=hf_token, repo_type=\"model\", private=False, exist_ok=True)\n",
    "\n",
    "adapter_dir = Path(\"tenacious_judge_adapter\")\n",
    "model.save_pretrained(adapter_dir)\n",
    "tokenizer.save_pretrained(adapter_dir)\n",
    "\n",
    "readme = f\"\"\"# Tenacious Judge LoRA\n",
    "\n",
    "Path B SimPO LoRA adapter for Tenacious-Bench sales-output preference scoring.\n",
    "\n",
    "- Backbone: `{BACKBONE_MODEL}`\n",
    "- Backbone note: {BACKBONE_NOTE}\n",
    "- Objective: SimPO via TRL `CPOTrainer`\n",
    "- Seed: `{SEED}`\n",
    "- Training pairs: `{len(train_data)}`\n",
    "- Eval pairs: `{len(eval_data)}`\n",
    "- Intended use: rejection-sampling or critique layer for Tenacious-style B2B sales outreach drafts\n",
    "- Known limitation: dual-control / premature-booking examples are underrepresented in the current preference set\n",
    "\"\"\"\n",
