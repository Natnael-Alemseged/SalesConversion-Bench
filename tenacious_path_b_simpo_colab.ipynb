    {
      "cell_type": "code",
      "source": [
        "# Cell 8 — Clean held-out preference-margin evaluation\n",
        "# Purpose:\n",
        "# Instead of asking the LoRA to freely generate PASS/FAIL text, score whether it\n",
        "# assigns higher likelihood to the reference-good output than the candidate output.\n",
        "#\n",
        "# Upload tenacious_bench_v0.2/held_out/tasks.jsonl to Colab as /content/tasks.jsonl\n",
        "\n",
        "import json, time, math\n",
        "from pathlib import Path\n",
        "from collections import Counter, defaultdict\n",
        "\n",
        "import torch\n",
        "import torch.nn.functional as F\n",
        "\n",
        "FastLanguageModel.for_inference(model)\n",
        "model.eval()\n",
        "\n",
        "heldout_path = Path(\"/content/tasks.jsonl\")\n",
        "if not heldout_path.exists():\n",
        "    raise FileNotFoundError(\n",
        "        \"Upload tenacious_bench_v0.2/held_out/tasks.jsonl to Colab as /content/tasks.jsonl\"\n",
        "    )\n",
        "\n",
        "heldout = [json.loads(line) for line in heldout_path.open() if line.strip()]\n",
        "print(\"held_out tasks:\", len(heldout))\n",
        "\n",
        "SYSTEM_PROMPT = \"\"\"You are a Tenacious Intelligence Corporation sales agent writing B2B outreach emails.\n",
        "\n",
        "Tenacious places managed engineering teams (Python, Go, data, ML, infra) for\n",
        "B2B SaaS and mid-market companies. You write direct, grounded, honest, professional,\n",
        "non-condescending outreach anchored to real hiring signals.\n",
        "\n",
        "Rules:\n",
        "- Subject: under 60 characters, states intent (Request / Context / Question / Re:)\n",
        "- Body: cold outreach max 120 words, warm reply max 200 words\n",
        "- Every claim grounded in the supplied signal brief\n",
        "- If signal confidence is medium/low, ask rather than assert\n",
        "- Never commit bench capacity beyond what bench_summary shows\n",
        "- Never use: world-class, top talent, A-players, rockstar, ninja, skyrocket,\n",
        "  supercharge, I hope this email finds you well, just following up, circling back,\n",
        "  quick question, quick chat, synergize, synergy, leverage, ecosystem,\n",
        "  game-changer, disruptor, paradigm shift, do not miss out, per my last email\n",
        "- Never use \"bench\" in prospect-facing copy; use \"engineering team\" or \"available capacity\"\n",
        "- One ask per message\n",
        "\n",
        "Respond with ONLY a JSON object: {\"subject\": \"...\", \"body\": \"...\"}\n",
        "\"\"\"\n",
        "\n",
        "def build_user_message(task):\n",
        "    inp = task.get(\"input\", {})\n",
        "    parts = [f\"Company: {inp.get('company_name', 'Unknown')}\"]\n",
        "    parts.append(f\"ICP segment: {inp.get('icp_segment', '?')}\")\n",
        "    parts.append(f\"Thread stage: {inp.get('thread_stage', 'cold_first_touch')}\")\n",
        "\n",
        "    sig = inp.get(\"signal_brief\", {})\n",
        "    parts.append(f\"Signal: {sig.get('signal_line', 'No signal provided')}\")\n",
        "    parts.append(f\"Signal confidence: {sig.get('signal_confidence_tier', 'unknown')}\")\n",
        "\n",
        "    bench = inp.get(\"bench_summary\")\n",
        "    if bench:\n",
        "        parts.append(f\"Bench summary: {json.dumps(bench, ensure_ascii=False)}\")\n",
        "\n",
        "    cap = inp.get(\"capacity_request\")\n",
        "    if cap:\n",
        "        parts.append(f\"Capacity request: {json.dumps(cap, ensure_ascii=False)}\")\n",
        "\n",
        "    thread = inp.get(\"prior_thread\")\n",
        "    if thread:\n",
        "        parts.append(f\"Prior thread: {json.dumps(thread, ensure_ascii=False)}\")\n",
        "\n",
        "    return \"\\n\".join(parts)\n",
        "\n",
        "def build_prompt(task):\n",
        "    return f\"[SYSTEM]\\n{SYSTEM_PROMPT}\\n\\n[CONTEXT]\\n{build_user_message(task)}\"\n",
        "\n",
        "def email_to_text(email):\n",
        "    if isinstance(email, dict):\n",
        "        return f\"Subject: {email.get('subject', '')}\\n\\n{email.get('body', '')}\".strip()\n",
        "    return str(email).strip()\n",
        "\n",
        "def completion_avg_logprob(prompt, completion):\n",
        "    prefix = prompt.rstrip() + \"\\n\\n\"\n",
        "    text = prefix + completion.lstrip()\n",
        "\n",
        "    prefix_ids = tokenizer(\n",
        "        prefix,\n",
        "        return_tensors=\"pt\",\n",
        "        truncation=True,\n",
        "        max_length=MAX_SEQ_LEN,\n",
        "    )[\"input_ids\"]\n",
        "\n",
        "    encoded = tokenizer(\n",
        "        text,\n",
        "        return_tensors=\"pt\",\n",
        "        truncation=True,\n",
        "        max_length=MAX_SEQ_LEN,\n",
        "    ).to(model.device)\n",
        "\n",
        "    input_ids = encoded[\"input_ids\"]\n",
        "\n",
        "    with torch.no_grad():\n",
        "        logits = model(**encoded).logits[:, :-1, :]\n",
        "\n",
        "    labels = input_ids[:, 1:]\n",
        "    log_probs = F.log_softmax(logits, dim=-1)\n",
        "    token_log_probs = log_probs.gather(-1, labels.unsqueeze(-1)).squeeze(-1)\n",
        "\n",
        "    start = max(0, min(prefix_ids.shape[1] - 1, token_log_probs.shape[1] - 1))\n",
        "    completion_log_probs = token_log_probs[:, start:]\n",
        "\n",
        "    if completion_log_probs.numel() == 0:\n",
        "        return float(\"nan\")\n",
        "\n",
        "    return float(completion_log_probs.mean().detach().cpu())\n",
        "\n",
        "artifact_dir = Path(\"training_artifacts\")\n",
        "artifact_dir.mkdir(exist_ok=True)\n",
        "\n",
        "out_path = artifact_dir / \"held_out_preference_margins.jsonl\"\n",
        "summary_path = artifact_dir / \"held_out_preference_summary.json\"\n",
        "\n",
        "rows = []\n",
        "latencies = []\n",
        "\n",
        "for task in heldout:\n",
        "    prompt = build_prompt(task)\n",
        "    chosen = email_to_text(task.get(\"ground_truth_output\", {}))\n",
        "    candidate = email_to_text(task.get(\"candidate_output\", {}))\n",
        "\n",
        "    same_text = chosen.strip() == candidate.strip()\n",
        "\n",
        "    start = time.time()\n",
        "    chosen_lp = completion_avg_logprob(prompt, chosen)\n",
        "    candidate_lp = completion_avg_logprob(prompt, candidate)\n",
        "    latency_ms = round((time.time() - start) * 1000, 2)\n",
        "\n",
        "    margin = chosen_lp - candidate_lp\n",
        "    prefers_reference = margin > 0\n",
        "\n",
        "    row = {\n",
        "        \"task_id\": task[\"task_id\"],\n",
        "        \"failure_category\": task.get(\"metadata\", {}).get(\"failure_category\"),\n",
        "        \"chosen_avg_logprob\": chosen_lp,\n",
        "        \"candidate_avg_logprob\": candidate_lp,\n",
        "        \"preference_margin\": margin,\n",
        "        \"prefers_reference\": prefers_reference,\n",
        "        \"same_text\": same_text,\n",
        "        \"latency_ms\": latency_ms,\n",
        "    }\n",
        "\n",
        "    rows.append(row)\n",
        "    latencies.append(latency_ms)\n",
        "\n",
        "with out_path.open(\"w\") as f:\n",
        "    for row in rows:\n",
        "        f.write(json.dumps(row, ensure_ascii=False) + \"\\n\")\n",
        "\n",
        "non_identical = [r for r in rows if not r[\"same_text\"]]\n",
        "all_pref_acc = sum(r[\"prefers_reference\"] or r[\"same_text\"] for r in rows) / len(rows)\n",
        "non_identical_pref_acc = (\n",
        "    sum(r[\"prefers_reference\"] for r in non_identical) / len(non_identical)\n",
        "    if non_identical else math.nan\n",
        ")\n",
        "\n",
        "by_category = {}\n",
        "for cat in sorted(set(r[\"failure_category\"] for r in rows)):\n",
        "    cat_rows = [r for r in rows if r[\"failure_category\"] == cat]\n",
        "    cat_non_identical = [r for r in cat_rows if not r[\"same_text\"]]\n",
        "    by_category[cat] = {\n",
        "        \"n\": len(cat_rows),\n",
        "        \"same_text\": sum(r[\"same_text\"] for r in cat_rows),\n",
        "        \"preference_accuracy_including_same_text\": (\n",
        "            sum(r[\"prefers_reference\"] or r[\"same_text\"] for r in cat_rows) / len(cat_rows)\n",
        "        ),\n",
        "        \"preference_accuracy_non_identical\": (\n",
        "            sum(r[\"prefers_reference\"] for r in cat_non_identical) / len(cat_non_identical)\n",
        "            if cat_non_identical else None\n",
        "        ),\n",
        "        \"mean_margin\": sum(r[\"preference_margin\"] for r in cat_rows) / len(cat_rows),\n",
        "    }\n",
        "\n",
        "summary = {\n",
        "    \"held_out_n\": len(rows),\n",
        "    \"non_identical_n\": len(non_identical),\n",
        "    \"same_text_n\": sum(r[\"same_text\"] for r in rows),\n",
        "    \"preference_accuracy_including_same_text\": all_pref_acc,\n",
        "    \"preference_accuracy_non_identical\": non_identical_pref_acc,\n",
        "    \"mean_margin\": sum(r[\"preference_margin\"] for r in rows) / len(rows),\n",
        "    \"latency_ms_p50\": sorted(latencies)[len(latencies) // 2],\n",
        "    \"latency_ms_mean\": sum(latencies) / len(latencies),\n",
        "    \"by_category\": by_category,\n",
        "    \"trace_path\": str(out_path),\n",
        "}\n",
        "\n",
        "summary_path.write_text(json.dumps(summary, indent=2) + \"\\n\")\n",
        "\n",
        "print(json.dumps(summary, indent=2))\n",
        "print(\"Saved traces:\", out_path)\n",
        "print(\"Saved summary:\", summary_path)\n"
      ],
